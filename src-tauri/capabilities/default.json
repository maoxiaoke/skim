{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Skim main window — custom commands carry their own path guard (safety.rs)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "opener:default",
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [{ "path": "**" }]
    },
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:default",
    "process:allow-relaunch"
  ]
}
